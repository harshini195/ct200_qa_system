# Optional. If unset, the system runs in MOCK mode for LLM generation
# (deterministic offline test cases) so the full flow is demoable without
# an API key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional. Where the SQLite DB file is created. Defaults to ./ct200.db
CT200_DB_PATH=ct200.db

# Optional. Where generated test-case JSON files are stored. Defaults to
# ./generations_store
CT200_GENERATIONS_DIR=generations_store
